<Window x:Class="ParameterRemapperUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        FontFamily="Arial"
        FontSize="16"
        Title="Circuit Renamer" MinHeight="500" MaxHeight="500" MinWidth="300" MaxWidth="600" ResizeMode="CanResizeWithGrip">
        
        <Grid Name="OptionGrid">
                <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20"/> <!--0 Left Border-->
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="20"/> <!--3 Right Border-->
                </Grid.ColumnDefinitions>
                
                <Grid.RowDefinitions>
                        <RowDefinition Height="20"/> <!--0 Top Border-->
                        <RowDefinition Height="Auto"/> 
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/> <!--10 Bottom Border-->
                </Grid.RowDefinitions>
                
                <TextBlock Margin="0,10,10,10" Grid.Column="1" Grid.Row="1" Text="Select Parameters:" HorizontalAlignment="Center"/>
                <ComboBox Margin="0,10,10,10" Name="ParameterDropDown1" Grid.Column="1" Grid.Row="2" DropDownClosed="OnDropDownClosedOnSelectionChanged"/>
                <ComboBox Margin="0,10,10,10" Name="ParameterDropDown2" Grid.Column="1" Grid.Row="3" DropDownClosed="OnDropDownClosedOnSelectionChanged"/>
                <ComboBox Margin="0,10,10,10" Name="ParameterDropDown3" Grid.Column="1" Grid.Row="4" DropDownClosed="OnDropDownClosedOnSelectionChanged"/>
                <ComboBox Margin="0,10,10,10" Name="ParameterDropDown4" Grid.Column="1" Grid.Row="5" DropDownClosed="OnDropDownClosedOnSelectionChanged"/>
                <ComboBox Margin="0,10,10,10" Name="ParameterDropDown5" Grid.Column="1" Grid.Row="6" DropDownClosed="OnDropDownClosedOnSelectionChanged"/>
                <ComboBox Margin="0,10,10,10" Name="ParameterDropDown6" Grid.Column="1" Grid.Row="7" DropDownClosed="OnDropDownClosedOnSelectionChanged"/>
                <ComboBox Margin="0,10,10,10" Name="ParameterDropDown7" Grid.Column="1" Grid.Row="8" DropDownClosed="OnDropDownClosedOnSelectionChanged"/>
                
                <TextBlock Margin="10,10,0,10" Grid.Column="2" Grid.Row="1" Text="Separator" HorizontalAlignment="Center"/>
                <TextBox Margin="10,10,0,10" Name="SeparatorTextBox1" Grid.Column="2" Grid.Row="2" LostKeyboardFocus="OnLostKeyboardFocus"/>
                <TextBox Margin="10,10,0,10" Name="SeparatorTextBox2" Grid.Column="2" Grid.Row="3" LostKeyboardFocus="OnLostKeyboardFocus"/>
                <TextBox Margin="10,10,0,10" Name="SeparatorTextBox3" Grid.Column="2" Grid.Row="4" LostKeyboardFocus="OnLostKeyboardFocus"/>
                <TextBox Margin="10,10,0,10" Name="SeparatorTextBox4" Grid.Column="2" Grid.Row="5" LostKeyboardFocus="OnLostKeyboardFocus"/>
                <TextBox Margin="10,10,0,10" Name="SeparatorTextBox5" Grid.Column="2" Grid.Row="6" LostKeyboardFocus="OnLostKeyboardFocus"/>
                <TextBox Margin="10,10,0,10" Name="SeparatorTextBox6" Grid.Column="2" Grid.Row="7" LostKeyboardFocus="OnLostKeyboardFocus"/>
                
                <TextBlock Name="Concatination" Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="9" MaxWidth="500" TextWrapping="Wrap" FontSize="12"/>
                
                <Button Name="SubmitButton" Grid.Column="1" Grid.Row="10" Margin="0,10,10,10" Content="Submit" Click="SubmitButton_OnClick"></Button>
        </Grid>
</Window>